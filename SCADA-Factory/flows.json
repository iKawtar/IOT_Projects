    {
        "id": "3865e0b351473296",
        "type": "function",
        "z": "5c6d60ef12726126",
        "name": "Send to ThingSpeak",
        "func": "var apiKey = \"GGSBXXG21LXLG10Y\";  \n\nvar url = \"https://api.thingspeak.com/update?api_key=\" + apiKey +\n\"&field1=\" + msg.m1_temp +\n\"&field2=\" + msg.m2_temp +\n\"&field3=\" + msg.m1_vib +\n\"&field4=\" + msg.m2_vib +\n\"&field5=\" + msg.humidite +\n\"&field6=\" + msg.conv_speed;\n\nmsg.url = url;\nreturn msg;",
        "outputs": 1,
