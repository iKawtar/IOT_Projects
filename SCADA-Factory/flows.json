    {
        "id": "59e06f0289a63fee",
        "type": "function",
        "z": "5c6d60ef12726126",
        "name": "Simulate industrial data",
        "func": "// RÉCUPÉRATION DES ÉTATS \nvar temp1 = flow.get('temp1') || 50;\nvar temp2 = flow.get('temp2') || 48;\nvar vibration1 = flow.get('vibration1') || 1.2;\nvar vibration2 = flow.get('vibration2') || 1.0;\nvar humidity = flow.get('humidity') || 45;\nvar speed = flow.get('speed') || 8;\nvar stress = flow.get('stress') || 0;\n\n// LOGIQUE DE SIMULATION\n\nstress += 0.01;\nif (stress > 5) stress = 5;\n\n// 2. Températures avec système de refroidissement (Loi de Newton)\n// On ajoute de la chaleur (stress) mais on en perd selon la température actuelle\nlet ambient = 25;\n\n// Moteur 1 : Monte vers ~75°C\ntemp1 += (0.5 + stress * 0.8) - ((temp1 - ambient) * 0.05) + (Math.random() - 0.5);\n\n// Moteur 2 : Plus stable, monte vers ~60°C\ntemp2 += (0.3 + stress * 0.6) - ((temp2 - ambient) * 0.04) + (Math.random() - 0.5);\n\n// 3. Vibrations liées à la vitesse et au stress\nvibration1 = 1.0 + (stress * 0.4) + (speed * 0.1) + (Math.random() - 0.5) * 0.2;\nvibration2 = 0.8 + (stress * 0.3) + (speed * 0.12) + (Math.random() - 0.5) * 0.2;\n\n// 4. Humidité (oscillation naturelle)\nhumidity = 50 + Math.sin(Date.now() / 10000) * 5 + (Math.random() - 0.5);\n\n// 5. Gestion de la Panne \nvar failure = (temp1 > 85 || vibration1 > 6.0 || temp2 > 85 || vibration2 > 6.0);\n\nif (failure) {\n    speed = Math.max(0, speed - 0.5); // Ralentissement progressif\n} else {\n    // Vitesse de croisière cible de 10 m/min avec légère variation\n    let targetSpeed = 10;\n    speed += (targetSpeed - speed) * 0.1 + (Math.random() - 0.5) * 0.2;\n}\n\n// ARRONDIS ET LIMITES\ntemp1 = Math.round(Math.min(Math.max(temp1, 20), 110));\ntemp2 = Math.round(Math.min(Math.max(temp2, 20), 110));\n\nvibration1 = Math.round(Math.min(Math.max(vibration1, 0), 10) * 10) / 10;\nvibration2 = Math.round(Math.min(Math.max(vibration2, 0), 10) * 10) / 10;\n\nhumidity = Math.round(Math.min(Math.max(humidity, 0), 100));\nspeed = Math.round(Math.min(Math.max(speed, 0), 15) * 10) / 10;\n\n// SAUVEGARDE ET ENVOI\nflow.set('temp1', temp1);\nflow.set('temp2', temp2);\nflow.set('vibration1', vibration1);\nflow.set('vibration2', vibration2);\nflow.set('humidity', humidity);\nflow.set('speed', speed);\n\nmsg.payload = {\n    temp1: temp1,\n    temp2: temp2,\n    vibration1: vibration1,\n    vibration2: vibration2,\n    humidity: humidity,\n    speed: speed,\n    failure: failure\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
