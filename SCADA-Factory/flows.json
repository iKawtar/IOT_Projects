    {
        "id": "8d66308c1f3a50ef",
        "type": "function",
        "z": "5c6d60ef12726126",
        "name": "Update Context",
        "func": "var t = msg.topic;\nvar v = parseFloat(msg.payload);\n\nif (t === 'atelier/m1/temp') flow.set('m1_temp', v);\nif (t === 'atelier/m2/temp') flow.set('m2_temp', v);\nif (t === 'atelier/m1/vibration') flow.set('m1_vib', v);\nif (t === 'atelier/m2/vibration') flow.set('m2_vib', v);\nif (t === 'atelier/ambiance/humidite') flow.set('humidite', v);\nif (t === 'atelier/convoyeur/vitesse') flow.set('conv_speed', v);\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 640,
        "wires": [
            [
                "2a40f89a947c2d3e"
            ]
        ]
    },
    {
        "id": "2a40f89a947c2d3e",
        "type": "function",
        "z": "5c6d60ef12726126",
        "name": "Constructeur SVG SCADA",
        "func": "function color(t) {\n    if (t < 50) return '#27ae60';\n    if (t < 80) return '#e67e22';\n    return '#e74c3c';\n}\n\nvar m1t = flow.get('m1_temp') || 0;\nvar m2t = flow.get('m2_temp') || 0;\nvar m1v = flow.get('m1_vib') || 0;\nvar m2v = flow.get('m2_vib') || 0;\nvar hum = flow.get('humidite') || 0;\nvar spd = flow.get('conv_speed') || 0;\n\nmsg.m1_temp = m1t;\nmsg.m1_color = color(m1t);\nmsg.m1_vib = m1v;\nmsg.m2_temp = m2t;\nmsg.m2_color = color(m2t);\nmsg.m2_vib = m2v;\nmsg.conv_speed = spd;\nmsg.conv_active = (spd > 0);\nmsg.humidite = hum;\nmsg.alerte = (m1t >= 80 || m2t >= 80 || m1v >= 4 || m2v >= 4);\nmsg.sys_status = msg.alerte ? 'ALARME SYSTEME' : 'SYSTEME NORMAL';\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 880,
        "y": 640,
        "wires": [
            [
                "c9a34516f0dfc9a1",
                "3865e0b351473296"
            ]
        ]
    },
    {
        "id": "c9a34516f0dfc9a1",
        "type": "ui_template",
        "z": "5c6d60ef12726126",
        "group": "b3d10e5083fe7147",
        "name": "SVG SCADA Atelier",
        "order": 1,
        "width": 12,
        "height": 9,
        "format": "<style>\n  @keyframes blink { 50% { opacity: 0.08; } }\n  @keyframes move  { from { stroke-dashoffset: 30; } to { stroke-dashoffset: 0; } }\n  .alerte-blink { animation: blink 0.55s step-start infinite; }\n  .conv-anim    { animation: move 1s linear infinite; }\n</style>\n<div style=\"background:#0d1117; padding:16px; border-radius:10px; font-family:monospace; color:#eee;\">\n  <div style=\"display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #30363d;\">\n    <span style=\"font-size:14px; font-weight:bold; color:#58a6ff;\">SCADA — ATELIER DE PRODUCTION</span>\n    <span style=\"font-size:12px; padding:4px 12px; border-radius:5px; font-weight:bold;\" ng-style=\"{'background': msg.alerte ? '#e74c3c' : '#27ae60', 'color': 'white'}\">{{msg.sys_status}}</span>\n  </div>\n  <svg width=\"100%\" viewBox=\"0 0 500 235\">\n    <rect x=\"8\" y=\"0\" width=\"100\" height=\"30\" rx=\"5\" fill=\"#1e272e\" stroke=\"#3498db\" stroke-width=\"1\"/>\n    <text x=\"58\" y=\"19\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"12\" font-weight=\"bold\" fill=\"#3498db\">HUM: {{msg.humidite}}%</text>\n    <g ng-class=\"{'alerte-blink': msg.m1_temp >= 80 || msg.m1_vib >= 4}\">\n      <rect x=\"8\" y=\"50\" width=\"132\" height=\"125\" rx=\"8\" style=\"fill:{{msg.m1_color}}; stroke:#2c3e50; stroke-width:2.5;\"/>\n    </g>\n    <rect x=\"18\" y=\"65\" width=\"62\" height=\"52\" rx=\"4\" fill=\"rgba(0,0,0,0.3)\"/>\n    <text x=\"74\" y=\"92\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"10\" font-weight=\"bold\" fill=\"white\">MOTEUR M1</text>\n    <text x=\"74\" y=\"120\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"26\" font-weight=\"bold\" fill=\"white\">{{msg.m1_temp}}</text>\n    <text x=\"74\" y=\"136\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"11\" fill=\"rgba(255,255,255,0.9)\">°C</text>\n    <rect x=\"20\" y=\"145\" width=\"108\" height=\"20\" rx=\"3\" fill=\"rgba(0,0,0,0.5)\"/>\n    <text x=\"74\" y=\"158\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"10\" fill=\"#f1c40f\">Vib: {{msg.m1_vib}} mm/s</text>\n    <rect x=\"140\" y=\"88\" width=\"220\" height=\"34\" rx=\"5\" fill=\"#1e272e\" stroke=\"#34495e\" stroke-width=\"1\"/>\n    <line x1=\"153\" y1=\"105\" x2=\"347\" y2=\"105\" stroke=\"#7f8c8d\" stroke-width=\"10\" stroke-dasharray=\"18 10\" ng-class=\"{'conv-anim': msg.conv_active}\"/>\n    <text x=\"250\" y=\"79\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"9\" fill=\"#8b949e\">CONVOYEUR PRINCIPAL</text>\n    <text x=\"250\" y=\"148\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"15\" font-weight=\"bold\" fill=\"white\">{{msg.conv_speed}} m/min</text>\n    <g ng-class=\"{'alerte-blink': msg.m2_temp >= 80 || msg.m2_vib >= 4}\">\n      <rect x=\"360\" y=\"50\" width=\"132\" height=\"125\" rx=\"8\" style=\"fill:{{msg.m2_color}}; stroke:#2c3e50; stroke-width:2.5;\"/>\n    </g>\n    <rect x=\"370\" y=\"65\" width=\"62\" height=\"52\" rx=\"4\" fill=\"rgba(0,0,0,0.3)\"/>\n    <text x=\"426\" y=\"92\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"10\" font-weight=\"bold\" fill=\"white\">MOTEUR M2</text>\n    <text x=\"426\" y=\"120\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"26\" font-weight=\"bold\" fill=\"white\">{{msg.m2_temp}}</text>\n    <text x=\"426\" y=\"136\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"11\" fill=\"rgba(255,255,255,0.9)\">°C</text>\n    <rect x=\"372\" y=\"145\" width=\"108\" height=\"20\" rx=\"3\" fill=\"rgba(0,0,0,0.5)\"/>\n    <text x=\"426\" y=\"158\" text-anchor=\"middle\" font-family=\"monospace\" font-size=\"10\" fill=\"#f1c40f\">Vib: {{msg.m2_vib}} mm/s</text>\n  </svg>\n</div>",
